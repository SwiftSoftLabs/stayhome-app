# StayHome environment

# JWT auth (phase 1 — first-party cookie auth)
NEXT_PUBLIC_DB_SCHEMA=app_stayhome
DATABASE_URL=postgresql://...
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
JWT_ACCESS_SECRET=replace_with_32_plus_char_secret
JWT_REFRESH_SECRET=replace_with_another_32_plus_char_secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
AUTH_VERIFY_CODE_TTL_SECONDS=900
AUTH_RESET_CODE_TTL_SECONDS=900
AUTH_BCRYPT_ROUNDS=12
AUTH_EMAIL_FROM=StayHome
INSFORGE_URL=https://your-project.us-east.insforge.app
INSFORGE_ANON_KEY=your_anon_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 2+3 auth
JWT_MFA_PENDING_TTL_SECONDS=300
AUTH_ENCRYPTION_KEY=replace_with_32_plus_char_encryption_key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=StayHome
WEBAUTHN_ORIGIN=http://localhost:3000
KELVIQ_VARIANT_PRO=stayhome-pro
